# Postgres connection string (Neon, Prisma Postgres, Supabase, local, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/blackquant?sslmode=require"

# Generate with: npx auth secret
AUTH_SECRET=""

# GitHub OAuth app credentials (https://github.com/settings/developers)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Help Desk assistant — any OpenAI-compatible provider (DeepSeek by default).
# DeepSeek key: https://platform.deepseek.com/api_keys
ASSISTANT_API_KEY=""
# Optional — switch providers without code changes (defaults shown):
#   ASSISTANT_BASE_URL="https://api.deepseek.com"
#     OpenRouter: https://openrouter.ai/api/v1 · Groq: https://api.groq.com/openai/v1 · Ollama: http://localhost:11434/v1
#   ASSISTANT_MODEL="deepseek-chat"
#     e.g. deepseek-chat · qwen/qwen-2.5-72b-instruct · llama-3.3-70b-versatile
