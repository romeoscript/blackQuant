# Postgres connection string (Neon, Prisma Postgres, Supabase, local, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/blackquant?sslmode=require"

# Generate with: npx auth secret
AUTH_SECRET=""

# GitHub OAuth app credentials (https://github.com/settings/developers)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Help Desk assistant — any OpenAI-compatible provider.
# Default is OpenRouter with a cheap vision model so screenshots work out of the box.
# OpenRouter key: https://openrouter.ai/keys
ASSISTANT_API_KEY=""
# Optional — switch providers/models without code changes (defaults shown):
#   ASSISTANT_BASE_URL="https://openrouter.ai/api/v1"
#     DeepSeek (text only): https://api.deepseek.com · Groq: https://api.groq.com/openai/v1 · Ollama: http://localhost:11434/v1
#   ASSISTANT_MODEL="google/gemini-2.0-flash-001"
#     vision, cheap/free: qwen/qwen-2.5-vl-72b-instruct · pick any at https://openrouter.ai/models?modality=text+image
#     text-only + cheapest: deepseek-chat (set ASSISTANT_BASE_URL to DeepSeek; images will be ignored)
